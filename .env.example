# DS TECHVIBE Portfolio - Single Environment Configuration
# Copy this file to .env and fill in your values
# All services (Frontend, Backend, Chatbot) read from this single file

# ============================================
# FRONTEND (Vite - React)
# ============================================
VITE_API_URL=http://localhost:5001/api

# ============================================
# BACKEND (Express - Node.js)
# ============================================
BACKEND_PORT=5001
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/portfolio
JWT_SECRET=your-super-secret-jwt-key-change-this
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123

# ============================================
# CHATBOT (Flask - Python)
# ============================================
CHATBOT_PORT=8000
GEMINI_API_KEY=your-google-gemini-api-key-here
DEBUG=False

# ============================================
# DEPLOYMENT OVERRIDES (Optional - for production)
# ============================================
# Uncomment and update these for Railway/Render/Vercel deployment
# VITE_API_URL=https://your-backend-url.railway.app/api
# BACKEND_PORT=5001
# NODE_ENV=production
# CHATBOT_URL=https://your-chatbot-url.railway.app/chat
# GEMINI_API_KEY=your-production-key
